# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your Home Assistant URL (no trailing slash)
HA_URL=http://homeassistant.local:8123

# Long-Lived Access Token from HA → Profile → Security → Long-Lived Access Tokens
HA_TOKEN=your_long_lived_token_here

# Host port Docker will expose the MCP server on (change this to avoid conflicts)
MCP_PORT=8000

# Comma-separated CIDRs allowed to connect. Defaults to unrestricted (0.0.0.0/0).
# Recommended: lock this to your local network, e.g. 192.168.178.0/24
MCP_ALLOWED_NETWORKS=192.168.178.0/24

# Optional SSL — leave both unset to run plain HTTP.
# MCP_SSL_DIR    = letsencrypt config root on the host (mounted at /certs in container)
# MCP_SSL_DOMAIN = domain name for the cert (selects /certs/live/<domain> inside container)
# MCP_SSL_DIR=/path/to/letsencrypt/config
# MCP_SSL_DOMAIN=yourdomain.com
